# =========================================================================
# ARECOFIX - .gitignore
# =========================================================================

# -------------------------------------------------------------------------
# DEPENDENCIAS Y ENTORNO NODE
# -------------------------------------------------------------------------
node_modules/
.npm
.yarn-integrity
.env
.env.*
!.env.example
.npmrc

# -------------------------------------------------------------------------
# LOCK FILES (solo se conserva pnpm-lock.yaml)
# -------------------------------------------------------------------------
package-lock.json
yarn.lock

# -------------------------------------------------------------------------
# LOGS
# -------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*
firebase-debug.*.log*

# -------------------------------------------------------------------------
# BUILDS, COMPILED Y BINARIOS
# -------------------------------------------------------------------------
dist/
deploy-temp/
releases/
firebase-public/
build/
build/Release/
*.apk
*.aab
*.exe
*.jar
*.rar
*.zip
*.tar.gz
*.tgz
*.mp4

# -------------------------------------------------------------------------
# ANGULAR / IONIC / FRONTEND
# -------------------------------------------------------------------------
.angular/
www/
routes.txt


# -------------------------------------------------------------------------
# FIREBASE & DATACONNECT
# -------------------------------------------------------------------------
.firebase/
.dataconnect/

# -------------------------------------------------------------------------
# CLOUDFLARE (Wrangler)
# -------------------------------------------------------------------------
.wrangler/

# -------------------------------------------------------------------------
# ANDROID / CAPACITOR (build artifacts)
# -------------------------------------------------------------------------
android/app/build/
android/.gradle/
android/capacitor-cordova-android-plugins/build/
android/local.properties

# -------------------------------------------------------------------------
# TAURI
# -------------------------------------------------------------------------
src-tauri/target/

# -------------------------------------------------------------------------
# TESTING & COVERAGE (Playwright, Karma, NYC)
# -------------------------------------------------------------------------
coverage/
.nyc_output/
lib-cov/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# -------------------------------------------------------------------------
# REPORTES, AUDITORÍAS Y HERRAMIENTAS
# -------------------------------------------------------------------------
.unlighthouse/
unlighthouse-report/

# -------------------------------------------------------------------------
# AI / AGENTES / PLANES TEMPORALES
# -------------------------------------------------------------------------
.agent/

# -------------------------------------------------------------------------
# SAMPLES, SCRATCH Y TEMPORALES
# -------------------------------------------------------------------------
AdsSample/
scratch/
test-og.js
test-og-more.js

# -------------------------------------------------------------------------
# SCRIPTS DE DEBUG CON CREDENCIALES
# -------------------------------------------------------------------------
scripts/debug-db.mjs
scripts/cleanup-database.js
scripts/meta_marketing_campaign.js

# -------------------------------------------------------------------------
# EDITOR / IDE
# -------------------------------------------------------------------------
.vscode/
.idea/

# -------------------------------------------------------------------------
# MISCELÁNEOS Y CACHÉS
# -------------------------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock
.eslintcache
.node_repl_history
bower_components/
.grunt/
.lock-wscript

# -------------------------------------------------------------------------
# SISTEMA OPERATIVO
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini